# ── PostgreSQL (external — not part of docker-compose) ──────────────────────
# Must be reachable from the backend container. On Docker Desktop (Win/Mac)
# use host.docker.internal instead of localhost if Postgres runs on the host.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/interdex?schema=public

# ── Backend ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=http://localhost:5173

# JWT secrets — generate with `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth 2.0 (create credentials at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Seeded admin account (created by `npm run prisma:seed`)
SEED_ADMIN_EMAIL=admin@interdex.dev
SEED_ADMIN_PASSWORD=ChangeMe123!

# ── Frontend (build-time) ────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
